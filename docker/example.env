MATRIX_HOMESERVER=
MATRIX_USERNAME=
MATRIX_PASSWORD=

# You can use a token instead of a password
# MATRIX_TOKEN=

# Name for bot's device
MATRIX_DEVICE=reminder-bot-device

# Only for verify your device and recover backup. 
# See "Recover" section in documentation or <recover> subcommand help page
# MATRIX_RECOVERY=recovery-key

# Timezone for reminders
TZ=Etc/UTC

# Language for bot messages
LANG_APP=en
# Alternative languages for users to choose from. In development
# LANG_APP_LIST=en,fr

# Alternative to !remind command to call the bot in a room
# Enter wihout exclamation mark
# LANG_BOT_COMMAND=